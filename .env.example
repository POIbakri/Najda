# ─────────────────────────────────────────────────────────────────────────────
# Najda environment variables
#
# Copy this file to `.env.local` and fill in the values. NEVER commit `.env*`.
#
# IMPORTANT: Najda runs fully in a self-contained DEMO MODE with NONE of these
# set — it uses a local client-side store, simulated realtime, a simulated
# responder, and simulated SMS so the live URL is demonstrable out of the box.
# Provide the values below to upgrade to real Supabase realtime + Twilio SMS.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Postgres + Realtime + RLS). Provided by the project owner.
# When BOTH are set, the app uses real Supabase instead of the demo store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio (WhatsApp-first, SMS fallback). Server-only — never exposed to the client.
# When all three are set, /api/dispatch sends real messages; otherwise it simulates.
#
# TWILIO_FROM decides the channel:
#   whatsapp:+14155238886   -> WhatsApp (faster, free for the user, rich preview).
#                              On a Twilio trial use the WhatsApp Sandbox number
#                              above; each responder must first send the join code
#                              (e.g. "join <two-words>") to it once to opt in.
#                              For production, use an approved WhatsApp Business sender.
#   +15714106146            -> plain SMS (works on any phone, even a feature phone).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886

# Optional: a plain-SMS sender used for the no-data fallback (alerts raised
# offline). When set, an offline-raised alert is delivered by REAL SMS; when
# unset, it falls back to TWILIO_FROM (WhatsApp). Either way the app reports the
# channel it actually used — it never claims SMS when WhatsApp went out.
# Example: TWILIO_SMS_FROM=+15714106146
TWILIO_SMS_FROM=

# Optional: public base URL used in SMS deep links (defaults to the request origin).
# Example: https://najda.vercel.app
NEXT_PUBLIC_BASE_URL=

# Demo-responder autopilot. When "on" (default), a Supabase-mode alert that no
# human answers within a few seconds is accepted by a clearly-labelled seeded
# "demo responder" that approaches and resolves — so a lone judge sees the full
# arc on the live URL. A real second device can still take over.
# MUST be set to "off" for a real community deployment.
NEXT_PUBLIC_DEMO_AUTOPILOT=on
