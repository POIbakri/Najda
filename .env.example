# ─────────────────────────────────────────────────────────────────────────────
# Najda environment variables
#
# Copy this file to `.env.local` and fill in the values. NEVER commit `.env*`.
#
# IMPORTANT: Najda runs fully in a self-contained DEMO MODE with NONE of these
# set — it uses a local client-side store, simulated realtime, a simulated
# responder, and simulated SMS so the live URL is demonstrable out of the box.
# Provide the values below to upgrade to real Supabase realtime + Twilio SMS.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Postgres + Realtime + RLS). Provided by the project owner.
# When BOTH are set, the app uses real Supabase instead of the demo store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio (WhatsApp/SMS fallback). Server-only — never exposed to the client.
# When all three are set, /api/dispatch sends real messages; otherwise it simulates.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Optional: public base URL used in SMS deep links (defaults to the request origin).
# Example: https://najda.vercel.app
NEXT_PUBLIC_BASE_URL=
